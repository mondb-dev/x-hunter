# LLM — Google Gemini (articles via write_article.js)
GOOGLE_API_KEY=

# LLM — OpenAI-compatible (checkpoints + ponder; works with OpenAI, xAI/Grok, etc.)
# For Grok: set OPENAI_API_BASE_HOST=api.x.ai and use your GROK_API_KEY value
OPENAI_API_KEY=
OPENAI_API_BASE_HOST=api.openai.com
OPENAI_MODEL=gpt-4o

# X (Twitter) credentials
X_USERNAME=
X_PASSWORD=

# OpenClaw browser profile name
OPENCLAW_PROFILE=x-hunter

# GitHub — for agent auto-commit + push
GITHUB_TOKEN=
GITHUB_REPO=mondb-dev/x-hunter
GIT_USER_NAME=x-hunter-agent
GIT_USER_EMAIL=agent@x-hunter.local
VERCEL_DEPLOY_HOOK=    # Optional: Project Settings → Git → Deploy Hooks → create hook → paste URL here

# Base wallet address to receive x402 micropayments (USDC on Base mainnet)
# Journal entries and daily belief reports are gated at $0.001 each
PAYMENT_ADDRESS=0xYourBaseWalletAddressHere

# Solana wallet — Sebastian's on-chain identity
# Generate with: node scripts/gen-wallet.js
SOLANA_PUBLIC_KEY=
SOLANA_PRIVATE_KEY=

# ── LLM backends (Claude CLI routing; each toggles independently) ────────────
# COMPOSE = outbound prose · THINK = cognition/research · BUILDER = self-mod builds
COMPOSE_BACKEND=claude
CLAUDE_COMPOSE_MODEL=sonnet
CLAUDE_COMPOSE_TIMEOUT_MS=120000
THINK_BACKEND=claude
CLAUDE_THINK_MODEL=sonnet
CLAUDE_THINK_TIMEOUT_MS=180000
BUILDER_BACKEND=claude
CLAUDE_BUILDER_MODEL=sonnet
CLAUDE_BUILDER_TIMEOUT_MS=600000
# Vertex fallback for the builder path (used when Claude fails or backend unset)
BUILDER_CREDENTIALS=
BUILDER_MODEL=gemini-2.5-pro
